---
const { lang, slug } = Astro.params;
const title = 'Demo Iframe';
---
<!doctype html>
<html lang={lang || 'en'}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <style>
    :root{--bg:#0f1125;--card:#0b0d17;--text:#e8eef6;--muted:rgba(232,238,246,0.72);--accent:#0ea5a4}
    html,body{height:100%;margin:0;font-family:Inter,system-ui,Arial;background:linear-gradient(180deg,#0b0d17,#0f1125);color:var(--text)}
    .wrap{max-width:980px;margin:48px auto;padding:24px}
    header{display:flex;align-items:center;gap:12px;margin-bottom:18px}
    h1{font-size:1.4rem;margin:0;color:var(--accent)}
    p{color:var(--muted);margin:8px 0 16px}
    .toolbar{display:flex;gap:12px;margin-bottom:16px}
    button{background:var(--accent);border:0;color:#042624;padding:10px 14px;border-radius:8px;font-weight:700;cursor:pointer}
    .info{background:var(--card);padding:12px;border-radius:8px;border:1px solid rgba(255,255,255,0.03)}
    textarea{width:100%;height:160px;margin-top:12px;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.04);background:#0a0b10;color:var(--text);resize:vertical}
    a.inline{display:inline-block;margin-left:8px;color:var(--accent);text-decoration:underline}
    footer{margin-top:18px;color:var(--muted);font-size:.9rem}
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity=".12" stroke-width="2"/><path d="M7 12h10M12 7v10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      <h1>{title}</h1>
    </header>

    <p>This page is a lightweight demo you can load inside the project iframe. It sends and receives postMessage with the parent and allows opening a fallback in a new tab.</p>

    <div class="toolbar">
      <button id="send">Send message to parent</button>
      <button id="open">Open example.com</button>
      <a class="inline" href={Astro.request.url} target="_blank" rel="noopener">Open standalone</a>
    </div>

    <div class="info">
      <div>Messages log (incoming from parent):</div>
      <textarea id="log" readonly></textarea>
    </div>

    <footer>Try clicking "Send message to parent" and watch console or parent listener for messages.</footer>
  </div>

  <script>
    // envia altura ao parent usando postMessage
    function sendHeight() {
      try {
        const h = Math.max(
          document.documentElement.scrollHeight,
          document.body.scrollHeight,
          document.documentElement.offsetHeight,
          document.body.offsetHeight
        );
        parent.postMessage({ type: 'demo:size', height: h }, '*');
      } catch (e) { /* cross-origin safety, ignore */ }
    }

    // observer para detectar mudanças internas
    const mo = new MutationObserver(() => sendHeight());
    window.addEventListener('load', () => {
      sendHeight();
      try {
        mo.observe(document.documentElement, { childList: true, subtree: true, attributes: true });
      } catch (err) {}
    });

    // também ao redimensionar a janela dentro do iframe
    window.addEventListener('resize', sendHeight);

    // exemplo de postMessage handshake
    const sendBtn = document.getElementById('send');
    const openBtn = document.getElementById('open');
    const log = document.getElementById('log');
    function logMsg(m){ log.value += m + "\\n"; log.scrollTop = log.scrollHeight; }

    window.addEventListener('message', e => {
      try {
        const d = e.data;
        if (typeof d === 'string') logMsg('parent: ' + d);
        else logMsg('parent: ' + JSON.stringify(d));
      } catch (err) {}
    });

    sendBtn.addEventListener('click', () => {
      try { parent.postMessage({ type: 'demo', text: 'Hello from iframe', timestamp: Date.now() }, '*'); logMsg('sent: Hello from iframe'); } catch (e) {}
    });
    openBtn.addEventListener('click', () => { window.open('https://example.com', '_blank'); });

    // cleanup on unload
    window.addEventListener('beforeunload', () => {
      try { mo.disconnect(); } catch(e) {}
    });
  </script>
</body>
</html>
