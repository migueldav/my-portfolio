---
const {
  title,
  description,
  image,
  locale = "en",
  path = ""
} = Astro.props;

const site = "https://migueldav.vercel.app";
const url = `${site}/${locale}${path}`;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Miguel",
  url: site,
  jobTitle: "Full-Stack Developer",
  sameAs: [
    "https://github.com/seuuser",
    "https://linkedin.com/in/seuuser"
  ]
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href={url} />

<link rel="alternate" hreflang="pt" href={`${site}/pt${path}`} />
<link rel="alternate" hreflang="en" href={`${site}/en${path}`} />
<link rel="alternate" hreflang="x-default" href={site} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:image" content={image} />
<meta property="og:url" content={url} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<link rel="icon" href="/favicon/favicon.ico" />

<script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

<script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>