---
import "../../styles/index.css";
import Head from "../../components/Head.astro";
import Navbar from "../../components/Navbar.astro";
import Hero from "../../components/Hero.astro";
import ProjectsCarousel from "../../components/ProjectsCarousel.astro";
import Skills from "../../components/Skills.astro";
import ExpandableList from "../../components/ExpandableList.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import { SITE } from "../../data/pt/site.js";
import { PROJECTS } from "../../data/pt/projects.js";
import { SKILLS, SKILLS_EXTRA } from "../../data/pt/skills.js";
import { UI } from "../../data/pt/ui.js";

const projects = PROJECTS;
---
<!doctype html>
<html lang="pt-BR">
  
  <head>
    <Head
      title={`Portfólio — ${SITE.name}`}
      description={SITE.description}
      image={SITE.ogImage}
      locale="pt"
      path=""
    />
  </head>

  <body>
    <div class="background-blur">
      <Navbar site={SITE} ui={UI} />

      <Hero site={SITE} ui={UI} />

      <main class="container" id="maincontent">
        <section id="about">
          <h2>{UI.aboutTitle}</h2>
          <p>{SITE.about}</p>
        </section>

        <Skills skills={SKILLS} extraSkills={SKILLS_EXTRA} locale="pt" />

        <ExpandableList id="extra-skills" title="Habilidades Extras" items={SKILLS_EXTRA} locale="pt" initiallyOpen={false} />

        <ProjectsCarousel projects={projects} locale="pt" />

        <Contact site={SITE} ui={UI} locale="pt" action="https://formspree.io/f/movkagjj" />
      </main>

      <Footer site={SITE} ui={UI} />
    </div>
    
    <script src="/js/smooth-scroll.js" defer></script>
    <script src="/js/header-toggle.js" defer></script>
    <script src="/js/contact-form.js" defer></script>
    <script src="/js/header-menu.js" defer></script>
    <script src="/js/carousel.js" defer></script>
    <script src="/js/lang-toggle.js" defer></script>
    <script src="/js/demo-modal.js" defer></script>
    <script src="/js/shine.js" defer></script>
  </body>
</html>
